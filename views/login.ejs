<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Sport Family</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
</head>
<body class="login-page">
    <main class="login-shell">
        <section class="login-card">
            <div class="login-logo-box">
                <img src="/img/logo-sf.png" alt="Sport Family Shoes" class="login-logo">
            </div>

            <h1 class="login-title">Sport Family</h1>
            <p class="subtitle">Tienda de Calzado Deportivo Premium</p>

            <% if (error) { %>
                <div class="error"><%= error %></div>
            <% } %>

            <form method="POST" action="/login">
                <div class="form-group">
                    <label for="usuario">Usuario</label>
                    <input type="text" id="usuario" name="usuario" required autocomplete="username" placeholder="admin">
                </div>

                <div class="form-group">
                    <label for="password">Contraseña</label>
                    <input type="password" id="password" name="password" required autocomplete="current-password" placeholder="123456">
                </div>

                <button type="submit" class="btn-login">Ingresar</button>
            </form>

            <div class="credentials">
                <strong>Credenciales de prueba</strong>
                <div class="cred-item">Usuario: <code>admin</code> | Pass: <code>123456</code></div>
                <div class="cred-item">Usuario: <code>cliente</code> | Pass: <code>123456</code></div>
                <div class="cred-item">Usuario: <code>test</code> | Pass: <code>123456</code></div>
            </div>
        </section>
    </main>
</body>
</html>
